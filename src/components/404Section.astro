    <div class="z-20 flex flex-col items-center justify-center gap-6">
      <div class="flex flex-col gap-6">
        <h1 class="text-3xl md:text-5xl font-Mono font-bold text-center text-white">404 - Seguimos en Construción...</h1>
        <p class="text-center text-white">Revisar la URL a la que apunta y si está mal escrita, corregirla</p>
      </div>

      <div class="text-center pt-10 font-normal justify-center font-Mono">
        <a href="/" aria-label="Ir a la página de inicio" class="flex gap-6 bg-orange text-white-cream items-center justify-center px-[2rem] py-[1rem] max-w-[250px] hover:bg-orange-800 transition-colors duration-250">
            <svg width="24" height="24" viewBox="0 0 24 24">
                <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                    <path d="M9.32 3.5L4.11 8.71a1.214 1.214 0 0 0 0 1.724l5.21 5.209" />
                    <path d="M20.249 20.5v-7.286a3.643 3.643 0 0 0-3.643-3.643H3.759" />
                </g>
            </svg>
            Volver Inicio
        </a>
      </div>
    </div>

      <!-- Fondos apilados -->
    {images.map((src, i) => (
      <div
        class={`slide-${i} absolute inset-0 z-10 bg-center bg-cover opacity-0`}
        style={`background-image: url(${src})`}
      />
    ))}

    <!-- Overlay oscuro -->
    <div class="absolute inset-0 z-10 bg-black/50" />


  </div>
</section>
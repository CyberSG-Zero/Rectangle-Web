---
const images = [
  "/img/bg-home/BG_Hero.avif",
  "/img/bg-home/BG_Hero-1.avif",
  "/img/bg-home/BG_Hero-2.avif",
  "/img/bg-home/BG_Hero-3.avif",
  "/img/bg-home/BG_Hero-4.avif",
  "/img/bg-home/BG_Hero-5.avif",
  "/img/bg-home/BG_Hero-6.avif"
];

const n = images.length;
const dur = n * 2; // duración total en segundos (2s por foto)

---
<style set:html={`
  @keyframes hero-show {
    0%, ${((1 / n) * 100).toFixed(2)}%  { opacity: 1; }
    ${((1 / n) * 100 + 0.01).toFixed(2)}%, 100% { opacity: 0; }
  }

  .slide-0 {
    opacity: 1;
    animation: hero-show ${dur}s 0s infinite;
  }

  ${images.map((_, i) => i === 0 ? '' : `
    .slide-${i} {
      opacity: 0;
      animation: hero-show ${dur}s ${i * 2}s infinite;
    }
  `).join('')}
`}></style>


<section class="relative w-full flex flex-col justify-center min-h-96 items-center h-screen">

  <!-- container -->
  <div class="max-w-360 flex flex-col w-full h-full justify-center items-center px-[0.875rem] py-[5rem]">

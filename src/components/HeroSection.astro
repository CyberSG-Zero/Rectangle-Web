---
const images = [
  "/img/bg-home/BG_Hero.avif",
  "/img/bg-home/BG_Hero-1.avif",
  "/img/bg-home/BG_Hero-2.avif",
  "/img/bg-home/BG_Hero-3.avif",
  "/img/bg-home/BG_Hero-4.avif",
  "/img/bg-home/BG_Hero-5.avif",
  "/img/bg-home/BG_Hero-6.avif"
];

const n = images.length;
const dur = n * 2;
---

<!-- 1. Preload SOLO la primera imagen (la que causa el LCP) -->
<link rel="preload" as="image" href={images[0]} fetchpriority="high" slot="head" />

<style set:html={`
  @keyframes hero-show {
    0%, ${((1 / n) * 100).toFixed(2)}%  { opacity: 1; }
    ${((1 / n) * 100 + 0.01).toFixed(2)}%, 100% { opacity: 0; }
  }

  .slide-0 {
    opacity: 1;
    animation: hero-show ${dur}s 0s infinite;
  }

  ${images.map((_, i) => i === 0 ? '' : `
    .slide-${i} {
      opacity: 0;
      animation: hero-show ${dur}s ${i * 2}s infinite;
    }
  `).join('')}
`}></style>

<section class="relative w-full flex justify-center h-[80dvh] min-h-96 items-center">
  <div class="max-w-360 flex w-full h-full justify-center items-center px-[0.875rem] py-[5rem]">
    <div class="z-20 flex flex-col items-center justify-center gap-[4rem]">
      <img src="img/white-logo.avif" alt="Logo del Rectangle" width="200" height="80">

      <div class="flex gap-4 items-center relative flex-wrap justify-center font-Mono font-normal">
        <a href="/reserva" class="bg-orange text-white-cream items-center justify-center px-[2rem] py-[1rem] max-w-[250px] hover:bg-orange-800 transition-colors duration-250">
          HAZ TU RESERVA
        </a>
        <a href="/carta" class="bg-white content-stretch flex items-center justify-center px-[2rem] py-[1rem] hover:bg-gray-200 transition-colors duration-250">
          NUESTRA CARTA
        </a>
      </div>
    </div>

    <!-- 2. Primera imagen como <img> real para que el navegador la detecte como LCP -->
    <img
      src={images[0]}
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      decoding="sync"
      class="slide-0 absolute inset-0 z-10 w-full h-full object-cover object-center"
    />

    <!-- 3. El resto siguen siendo divs con background-image, pero con loading diferido -->
    {images.slice(1).map((src, i) => (
      <div
        class={`slide-${i + 1} absolute inset-0 z-10 bg-center bg-cover opacity-0`}
        style={`background-image: url(${src})`}
      />
    ))}

    <div class="absolute inset-0 z-10 bg-black/50" />
  </div>
</section>
---
import Layout from "../layouts/Layout.astro";

---

<Layout title="El Rectangle | error 404" >
    <main class="px-4 flex flex-col items-center justify-center h-screen text-white">
        <div class="pt-52 h-screen flex flex-col items-center justify-center gap-6">

            <h1 class="text-3xl md:text-5xl font-bold text-center text-wine">404 - Page not found</h1>
            <p class="text-center text-white">
            Revisar la URL a la que apunta y si está mal escrita, corregirla
            </p>
            <div class="text-center pt-10">
            <a href="/" class="rounded-md bg-white sand-700 text-black mx-auto p-4 hover:border-4 border-yellow-400">Volver Inicio</a>
            </div>
        </div>
    </main>
</Layout>